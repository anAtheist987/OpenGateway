# Document Agent - example environment
# Copy to .env and fill in values: cp example.env .env

# --------------------------------------------
# LLM for extraction (MCP uses this)
# --------------------------------------------
# Option 1: LiteLLM (e.g. Qwen / OpenAI-compatible)
LITELLM_MODEL="openai/qwen3.5-27b-fp8"
# DASHSCOPE_API_KEY="your-dashscope-key"
# Or OpenAI:
# LITELLM_MODEL="openai/gpt-4o-mini"
# OPENAI_API_KEY="your-openai-key"

# Option 2: Google (optional, if not using LiteLLM)
# GOOGLE_API_KEY="your-google-api-key"
# LITELLM_MODEL="gemini-2.5-flash"

# --------------------------------------------
# Agent URL (for Host / Registry)
# --------------------------------------------
APP_URL="http://127.0.0.1:10008"

# --------------------------------------------
# Document Agent LLM mode switch (local/api)
# --------------------------------------------
# local: use locally deployed OpenAI-compatible endpoint
# api  : use remote API endpoint
DOCUMENT_LLM_MODE="api"

# Local deployment settings
DOCUMENT_LOCAL_MODEL="openai/qwen3.5-27b-fp8"
DOCUMENT_LOCAL_API_BASE="http://localhost:8888/"
DOCUMENT_LOCAL_API_KEY="EMPTY"

# Remote API settings
DOCUMENT_API_MODEL="openai/qwen3.5-27b-fp8"
DOCUMENT_API_BASE="https://api.anthropic.com"
# DOCUMENT_API_KEY="your-api-key"
