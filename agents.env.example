# =============================================================================
# agents.env — AgentGateway 多 Agent 系统 API Key 统一配置文件
#
# 使用方式：
#   cp agents.env.example agents.env
#   # 编辑 agents.env，填入真实的 key
#   bash start-all.sh          # 自动 source agents.env
#
# 注意：agents.env 已加入 .gitignore，不会被提交到版本库。
# =============================================================================

# ── 必填 ──────────────────────────────────────────────────────────────────────

# DashScope API Key（所有 LLM 调用，支持 Qwen 系列模型）
# 获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY="sk-xxxx"

# ── 可选：影响可用的 Agent ────────────────────────────────────────────────────

# SerpAPI Key（缺失则跳过：航班 / 酒店 / 活动 / 金融 4 个 Agent）
# 获取：https://serpapi.com/dashboard
# 免费额度：100 次/月
SERPAPI_KEY=""

# TripAdvisor Content API Key（缺失则跳过：猫途鹰景点 Agent）
# 获取：https://www.tripadvisor.com/developers
TRIPADVISOR_API_KEY=""

# Google API Key（缺失则跳过：Airbnb Agent）
# 获取：https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=""

# ── 可选：覆盖 LLM 默认配置 ──────────────────────────────────────────────────

# 默认使用 DashScope qwen-plus；如需切换模型可在此修改
# LITELLM_MODEL="openai/qwen-plus"
# LITELLM_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ── 可选：Anthropic API Key（Claude Sonnet 4.6 端点）──────────────────────────
# 以下 5 个 Agent 使用 Claude Sonnet 4.6：
#   - WeatherAgent     (agents_in_use/weather_agent_claude)
#   - HotelAgent       (agents_in_use/hotel_agent_claude)
#   - FinanceDocAgent  (agents_in_use/finance_document_agent)
#   - InfosecDocAgent  (agents_in_use/infosec_document_agent)
#   - DeptDocAgent     (agents_in_use/dept_doc_reader_agent)
#
# start-all.sh 会自动将此 key 同时 export 为：
#   ANTHROPIC_API_KEY  → 供 Weather/Hotel Claude Agent 使用
#   DOCUMENT_API_KEY   → 供三个 Doc Agent 使用
#
# 未填写时：上述 5 个 Agent 调用 LLM 将因鉴权失败返回 405/401。
# 获取：https://console.anthropic.com/ 或其他 Anthropic 兼容 API 提供商
DOCUMENT_API_KEY=""

# 以下三项由 start-all.sh 自动注入，通常无需手动设置
# DOCUMENT_API_BASE="https://api.anthropic.com"       # Anthropic API 端点（可替换为兼容端点）
# DOCUMENT_API_MODEL="anthropic/claude-sonnet-4-6"    # Doc Agent 模型
# ANTHROPIC_API_BASE="https://api.anthropic.com"      # Weather/Hotel Claude Agent 使用
